{
  "amp.mcpServers": {
    "database": {
      "args": [
        "-y",
        "@bytebase/dbhub",
        "--dsn",
        "postgresql://user:pass@localhost:5432/db"
      ],
      "command": "npx",
      "enabled": true,
      "env": {
        "DATABASE_URL": "postgresql://user:pass@localhost:5432/db"
      },
      "type": "stdio"
    },
    "linear": {
      "enabled": true,
      "type": "http",
      "url": "https://mcp.linear.app/sse"
    },
    "playwright": {
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headless"
      ],
      "command": "npx"
    }
  }
}
