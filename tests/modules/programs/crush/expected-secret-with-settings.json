{
  "lsp": {
    "go": {
      "command": "gopls"
    },
    "rust": {
      "command": "rust-analyzer"
    }
  },
  "options": {
    "disabled_tools": [
      "sourcegraph"
    ],
    "initialize_as": "AGENTS.md"
  },
  "providers": {
    "anthropic": {
      "api_key": "$ANTHROPIC_API_KEY"
    },
    "openai": {
      "api_key": "$OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1"
    }
  }
}
