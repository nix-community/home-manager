{
  "mcp": {
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/tmp"
      ],
      "command": "npx",
      "timeout": 120,
      "type": "stdio"
    },
    "github": {
      "headers": {
        "Authorization": "Bearer $(echo $GH_PAT)"
      },
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "streaming": {
      "disabled_tools": [
        "some-tool"
      ],
      "headers": {
        "API-Key": "$(echo $API_KEY)"
      },
      "type": "sse",
      "url": "https://example.com/mcp/sse"
    }
  }
}
