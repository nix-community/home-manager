{
  config,
  lib,
  pkgs,
  ...
}:
let
  firefoxMockOverlay = import ./setup-firefox-mock-overlay.nix [
    "programs"
    "librewolf"
  ];

  expectedOverrides = pkgs.writeText "expected-librewolf-overrides.cfg" ''
    // Generated by Home Manager.

    defaultPref("privacy.resistFingerprinting", false);
    defaultPref("webgl.disabled", false);

  '';

  configPath = ".librewolf-custom";

  nmhSuffix =
    if pkgs.stdenv.hostPlatform.isDarwin then "NativeMessagingHosts" else "native-messaging-hosts";

  nmhHost = pkgs.writeTextDir "lib/mozilla/native-messaging-hosts/com.example.nmh.json" ''
    {"name":"com.example.nmh"}
  '';
in
{
  imports = [ firefoxMockOverlay ];

  config = lib.mkIf config.test.enableBig {
    programs.librewolf = {
      enable = true;
      inherit configPath;
      settings = {
        "privacy.resistFingerprinting" = false;
        "webgl.disabled" = false;
      };
      nativeMessagingHosts = [ nmhHost ];
    };

    nmt.script = ''
      assertFileContent \
        home-files/${configPath}/librewolf.overrides.cfg \
        ${expectedOverrides}

      assertFileExists \
        home-files/${configPath}/${nmhSuffix}/com.example.nmh.json

      assertPathNotExists home-files/.librewolf/librewolf.overrides.cfg
      assertPathNotExists home-files/.librewolf/native-messaging-hosts
      ${lib.optionalString pkgs.stdenv.hostPlatform.isDarwin ''
        assertPathNotExists "home-files/Library/Application Support/LibreWolf/NativeMessagingHosts"
      ''}
    '';
  };
}
