configuration {
cycle: false;
font: "Droid Sans Mono 14";
kb-primary-paste: "Control+V,Shift+Insert";
kb-secondary-paste: "Control+v,Insert";
location: 0;
modes: [ "drun","emoji","ssh","foo:bar" ];
terminal: "/some/path";
xoffset: 0;
yoffset: 0;
}

filebrowser {
directories-first: true;
directory: "$HOME";
sorting-method: "name";
}

run,drun {
display-name: "open:";
}
